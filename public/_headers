# Cloudflare Pages — HTTP headers override
# Fixes Content-Type for sitemap.xml (TanStack server route sets it correctly
# but Cloudflare strips custom headers; this file enforces the correct type).

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  X-Robots-Tag: noindex
  Cache-Control: public, max-age=0, s-maxage=1800, stale-while-revalidate=3600

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

/google4e56815144526e71.html
  Content-Type: text/html; charset=utf-8
  Cache-Control: public, max-age=86400
